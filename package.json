{
  "name": "e7g",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vp run --filter @e7g/web dev",
    "build": "vp run --filter @e7g/web build",
    "preview": "vp run --filter @e7g/web preview",
    "typecheck": "vp exec --filter @e7g/web -- svelte-kit sync && vp exec --filter @e7g/web -- svelte-check --tsconfig ./tsconfig.json"
  },
  "devDependencies": {
    "vite-plus": "^0.2.5"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "latest"
    }
  },
  "packageManager": "pnpm@10.15.1"
}
